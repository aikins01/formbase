{
  "name": "@formbase/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- tsx watch --clear-screen=false src/index.ts",
    "lint": "eslint . --cache --max-warnings 0",
    "start": "dotenv -e ../../.env.local -- tsx src/index.ts",
    "typecheck": "tsc --noEmit --tsBuildInfoFile .tsbuildinfo"
  },
  "dependencies": {
    "@formbase/db": "workspace:*",
    "@formbase/env": "workspace:*",
    "@formbase/queue": "workspace:*"
  },
  "devDependencies": {
    "@formbase/tsconfig": "workspace:*",
    "dotenv-cli": "^7.4.2",
    "eslint-config-formbase": "workspace:*",
    "tsx": "^4.15.5"
  }
}
